{
  "manifest_version": 3,
  "name": "FocusTrack — Time & Productivity",
  "version": "1.0.0",
  "description": "Tracks time on websites, classifies productivity, and syncs analytics to your dashboard.",
  "permissions": ["storage", "alarms", "tabs", "idle"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "FocusTrack",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
